ARG BASE_IMAGE=debian:bookworm
FROM ${BASE_IMAGE}

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
        gcc \
        clang \
        clang-tidy \
        cmake \
        make \
        git \
        valgrind \
        doxygen \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app
