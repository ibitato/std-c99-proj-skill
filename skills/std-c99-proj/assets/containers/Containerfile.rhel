ARG BASE_IMAGE=rockylinux:9
FROM ${BASE_IMAGE}

# Enable EPEL and CRB/PowerTools for doxygen and clang-tools-extra
RUN dnf install -y epel-release \
    && dnf config-manager --set-enabled crb 2>/dev/null \
    || dnf config-manager --set-enabled powertools 2>/dev/null \
    || true

RUN dnf install -y \
        gcc \
        clang \
        clang-tools-extra \
        cmake \
        make \
        git \
        valgrind \
        doxygen \
    && dnf clean all

WORKDIR /app
